---
import ToolLandingLayout from '../../layouts/ToolLandingLayout.astro';
import { OCRToolPage } from '@lunedoc/tools';
import { OCR_PAGE } from '../../data/ocr-pdf';
import type { Lang } from '@lunedoc/i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'tr' } },
    { params: { lang: 'es' } },
  ];
}

// `lang` here is constrained to 'tr' | 'es' by getStaticPaths. We assert
// to the wider Lang union so the OCR_PAGE[lang] lookup is well-typed.
const { lang: rawLang } = Astro.params;
const lang = rawLang as Lang;
const content = OCR_PAGE[lang];
---

<ToolLandingLayout
  lang={lang}
  canonicalPath="/ocr-pdf"
  toolDisplayName="OCR PDF"
  toolIconName="ocr"
  toolBadgeTone={290}
  content={content}
  relatedToolKeys={['watermark', 'edit', 'sign', 'compress']}
>
  <div style="max-width: 1080px; margin: 0 auto; padding: 0 1.5rem;">
    <OCRToolPage lang={lang} client:load />
  </div>
</ToolLandingLayout>
