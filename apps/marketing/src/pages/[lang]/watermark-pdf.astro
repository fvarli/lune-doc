---
import ToolLandingLayout from '../../layouts/ToolLandingLayout.astro';
import { WatermarkToolPage } from '@lunedoc/tools';
import { WATERMARK_PAGE } from '../../data/watermark-pdf';
import type { Lang } from '@lunedoc/i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'tr' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as Lang;
const content = WATERMARK_PAGE[lang];
---

<ToolLandingLayout
  lang={lang}
  canonicalPath="/watermark-pdf"
  toolDisplayName="Watermark PDF"
  toolIconName="watermark"
  toolBadgeTone={290}
  content={content}
  relatedToolKeys={['edit', 'sign', 'compress', 'merge']}
>
  <div style="max-width: 1080px; margin: 0 auto; padding: 0 1.5rem;">
    <WatermarkToolPage lang={lang} client:load />
  </div>
</ToolLandingLayout>
