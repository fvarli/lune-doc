---
import ToolLandingLayout from '../../layouts/ToolLandingLayout.astro';
import { CompressToolPage } from '@lunedoc/tools';
import { COMPRESS_PAGE } from '../../data/compress-pdf';
import type { Lang } from '@lunedoc/i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'tr' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: rawLang } = Astro.params;
const lang = rawLang as Lang;
const content = COMPRESS_PAGE[lang];
---

<ToolLandingLayout
  lang={lang}
  canonicalPath="/compress-pdf"
  toolDisplayName="Compress PDF"
  toolIconName="compress"
  toolBadgeTone={200}
  content={content}
  relatedToolKeys={['convert', 'merge', 'split', 'edit']}
>
  <div style="max-width: 1080px; margin: 0 auto; padding: 0 1.5rem;">
    <CompressToolPage lang={lang} client:load />
  </div>
</ToolLandingLayout>
