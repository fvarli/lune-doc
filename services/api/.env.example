# Lunedoc API — local environment.
# Copy to .env and fill in. .env is gitignored.

# --- Postgres ---
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# Create the role + db with the README's one-time setup commands.
DATABASE_URL=postgresql+asyncpg://lunedoc:CHANGEME@localhost:5432/lunedoc_dev

# Sync URL (used by Alembic + Celery sweeper). Same host/db, sync driver.
DATABASE_URL_SYNC=postgresql+psycopg2://lunedoc:CHANGEME@localhost:5432/lunedoc_dev

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Storage (local disk) ---
# Relative to services/api/. Gitignored.
STORAGE_ROOT=.local-storage

# --- Owner-token HMAC pepper ---
# Required. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
OWNER_TOKEN_PEPPER=replace-me-with-a-real-secret

# --- Limits ---
MAX_UPLOAD_BYTES=52428800        # 50 MB
FILE_TTL_SECONDS=3600            # 1 hour

# --- Phase 4 — auth ---
# Two mandatory secrets — keep them DIFFERENT.
# Generate each independently with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=replace-me-with-a-real-secret
AUTH_CHALLENGE_PEPPER=replace-me-with-a-real-secret

ACCESS_TOKEN_TTL_SECONDS=900             # 15 min
REFRESH_TOKEN_TTL_SECONDS=2592000        # 30 days
EMAIL_CHALLENGE_TTL_SECONDS=900          # 15 min
EMAIL_CHALLENGE_MAX_ATTEMPTS=5

# Email delivery. "console" prints the verification link + code to
# stdout; suitable for dev/test. Real backends added in later steps.
EMAIL_BACKEND=console
EMAIL_FROM=no-reply@lunedoc.local
# Used to compose the magic-link URL. Frontend wires Step 2.
FRONTEND_BASE_URL=http://localhost:5173

# Rate limits on POST /auth/email/start (Redis-backed).
EMAIL_START_RATE_PER_EMAIL_PER_HOUR=5
EMAIL_START_RATE_PER_IP_PER_HOUR=20

# --- CORS ---
# Comma-separated list of origins. Empty = same-origin only.
CORS_ORIGINS=http://localhost:5173,http://localhost:4321,http://localhost:8765
